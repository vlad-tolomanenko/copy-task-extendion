{
  "author": "Vlad Tolomanenko",
  "manifest_version": 3,
  "name": "Task Link Copier",
  "short_name": "TaskCopier",
  "version": "1.0.0",
  "description": "Copy task titles and links in Markdown, HTML, or plain text — works with Asana and other project management tools",
  "minimum_chrome_version": "102",
  "homepage_url": "https://github.com/vlad-tolomanenko/copy-task-extendion",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "https://app.asana.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://app.asana.com/*"],
      "js": ["i18n.js", "content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "copy-task": {
      "suggested_key": {
        "default": "Alt+Shift+C"
      },
      "description": "Copy task link"
    }
  },
  "options_page": "options.html"
}
